# 데이터베이스 접속 정보
# FastAPI 서버를 GPU 서버(team05 계정)에서 같이 실행하면 DB_HOST는 127.0.0.1 입니다.
# 로컬 PC에서 SSH 터널을 열어 접속해도 DB_HOST는 127.0.0.1 입니다.
#   ssh -N -L 54320:127.0.0.1:54320 <GPU_USER>@<GPU_SERVER_IP>
# GPU 서버의 PostgreSQL 54320 포트가 외부에 직접 열려 있을 때만 DB_HOST를 <GPU_SERVER_IP>로 바꾸세요.
DB_USER=team05_db
DB_PASSWORD=secret-db-password
DB_NAME=team05_db
DB_HOST=127.0.0.1
DB_PORT=54320
DB_MAX_SIZE=10
DB_MIN_SIZE=5

# JWT 토큰 인증 정보
SECRET_KEY=your-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30 # 30분
REFRESH_TOKEN_EXPIRE_DAYS=30 # 30일

# 로깅 정보
LOGGING_DIR=logs
FILE_NAME=server.log
WHEN=midnight
INTERVAL=1
BACKUP=7

FORMAT=%(asctime)s %(levelname)s %(message)s
DATEFMT=%m/%d/%Y %I:%M:%S %p

# 초기 관리자 계정 생성 스크립트용
INITIAL_USER_ID=admin_team05
INITIAL_USER_PASSWORD=ChangeThis05!

# 프론트엔드 개발 서버 허용 origin
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
