<?xml version="1.0" ?>
<robot name="robot_system" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find robot_system_description)/urdf/materials.xacro" />

<link name="world"/>
<joint name="fixed_to_world" type="fixed">
  <parent link="world"/>
  <child link="base_link"/>
</joint>

<link name="base_link">
  <inertial>
    <origin xyz="-0.036965141881106514 -9.562908641042548e-17 0.06102885117512971" rpy="0 0 0"/>
    <mass value="764.5040316870028"/>
    <inertia ixx="110.516115" iyy="99.10948" izz="203.495293" ixy="0.0" iyz="0.0" ixz="2.938225"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="y_link_1">
  <inertial>
    <origin xyz="0.030000000000000013 0.0 0.0" rpy="0 0 0"/>
    <mass value="7.0649999999999995"/>
    <inertia ixx="0.038916" iyy="0.038916" izz="0.004239" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.05 -0.0 -0.225" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/y_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.05 -0.0 -0.225" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/y_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="z_link_1">
  <inertial>
    <origin xyz="0.030000000000000013 -3.947459643111668e-18 0.0" rpy="0 0 0"/>
    <mass value="0.5651999999999999"/>
    <inertia ixx="0.000188" iyy="0.000188" izz="0.000339" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.11 -0.0 -0.225" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/z_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.11 -0.0 -0.225" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/z_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="theta_link_1">
  <inertial>
    <origin xyz="0.0001732869481511634 -1.9700445167097035e-18 -0.0303093012095626" rpy="0 0 0"/>
    <mass value="0.07078216289539181"/>
    <inertia ixx="1.2e-05" iyy="1e-05" izz="6e-06" ixy="-0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.14 0.0 -0.215" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/theta_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.14 0.0 -0.215" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/theta_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="x_link_1">
  <inertial>
    <origin xyz="8.91814442532711e-18 0.55 0.07933333333333334" rpy="0 0 0"/>
    <mass value="35.324999999999996"/>
    <inertia ixx="3.728361" iyy="0.035388" izz="3.751849" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.0 0.55 -0.165" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/x_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.0 0.55 -0.165" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/x_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="joint_y" type="prismatic">
  <origin xyz="0.05 0.55 0.06" rpy="0 0 0"/>
  <parent link="x_link_1"/>
  <child link="y_link_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit upper="0.4" lower="-0.4" effort="30" velocity="0.2"/>
  <dynamics damping="25.0" friction="2.0"/>
</joint>

<joint name="joint_z" type="prismatic">
  <origin xyz="0.06 0.0 0.0" rpy="0 0 0"/>
  <parent link="y_link_1"/>
  <child link="z_link_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit upper="0.1" lower="-0.115" effort="80" velocity="0.25"/>
  <dynamics damping="3.0" friction="0.05"/>
</joint>

<joint name="joint_theta" type="continuous">
  <origin xyz="0.03 -0.0 -0.01" rpy="0 0 0"/>
  <parent link="z_link_1"/>
  <child link="theta_link_1"/>
  <axis xyz="-0.0 0.0 -1.0"/>
  <dynamics damping="0.2" friction="0.05"/>
</joint>

<joint name="joint_x" type="prismatic">
  <origin xyz="0.0 -0.55 0.165" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="x_link_1"/>
  <axis xyz="1.0 0.0 0.0"/>
  <limit upper="0.4" lower="-0.4" effort="40" velocity="0.2"/>
  <dynamics damping="30.0" friction="2.0"/>
</joint>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="macro_camera">
    <update_rate>30.0</update_rate>
    <topic>vision/macro_camera/image_raw</topic>
    <camera>
      <horizontal_fov>1.047</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.01</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose>0.0125 0 -0.038 0 1.5708 1.5708</pose> 
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="micro_camera_1">
    <update_rate>30.0</update_rate>
    <topic>vision/micro_camera_1/image_raw</topic>
    <camera>
      <horizontal_fov>0.11</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.005</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose> 0.006  0.006 -0.0435 0 1.5708 1.5708</pose> 
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="micro_camera_2">
    <update_rate>30.0</update_rate>
    <topic>vision/micro_camera_2/image_raw</topic>
    <camera>
      <horizontal_fov>0.11</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.005</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose> -0.006  0.006 -0.0435 0 1.5708 1.5708</pose>
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="micro_camera_3">
    <update_rate>30.0</update_rate>
    <topic>vision/micro_camera_3/image_raw</topic>
    <camera>
      <horizontal_fov>0.11</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.005</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose> -0.006  -0.006 -0.0435 0 1.5708 1.5708</pose> 
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="micro_camera_4">
    <update_rate>30.0</update_rate>
    <topic>vision/micro_camera_4/image_raw</topic>
    <camera>
      <horizontal_fov>0.11</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.005</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose> 0.006  -0.006 -0.0435 0 1.5708 1.5708</pose> 
  </sensor>
</gazebo>

<gazebo>
  <plugin filename="libignition-gazebo-joint-position-controller-system.so"
          name="ignition::gazebo::systems::JointPositionController">
    <joint_name>joint_x</joint_name>
    <topic>/model/robot_system/joint/joint_x/cmd_pos</topic>
    <p_gain>30.0</p_gain>
    <i_gain>0.0</i_gain>
    <d_gain>8.0</d_gain> 
  </plugin>

  <plugin filename="libignition-gazebo-joint-position-controller-system.so"
          name="ignition::gazebo::systems::JointPositionController">
    <joint_name>joint_y</joint_name>
    <topic>/model/robot_system/joint/joint_y/cmd_pos</topic>
    <p_gain>25.0</p_gain>
    <i_gain>0.0</i_gain>
    <d_gain>7.0</d_gain>
  </plugin>

  <plugin filename="libignition-gazebo-joint-position-controller-system.so"
          name="ignition::gazebo::systems::JointPositionController">
    <joint_name>joint_z</joint_name>
    <topic>/model/robot_system/joint/joint_z/cmd_pos</topic>
    <p_gain>80.0</p_gain>
    <i_gain>0.0</i_gain>
    <d_gain>8.0</d_gain>
  </plugin>
</gazebo>

<gazebo>
  <plugin filename="libignition-gazebo-joint-position-controller-system.so"
          name="ignition::gazebo::systems::JointPositionController">
    <joint_name>joint_theta</joint_name>
    <topic>/model/robot_system/joint/joint_theta/cmd_pos</topic>
    <p_gain>0.3</p_gain>
    <i_gain>0.0</i_gain>
    <d_gain>0.03</d_gain>
  </plugin>
</gazebo>


<gazebo>
    <plugin filename="libignition-gazebo-sensors-system.so" 
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>

<gazebo reference="theta_link_1">
  <light name="gripper_led" type="point">
    <pose>0 0 -0.05 0 0 0</pose> 
    
    <diffuse>1.0 1.0 1.0 1.0</diffuse>
    <specular>1.0 1.0 1.0 1.0</specular>

    <visualize>false</visualize>

    <attenuation>
      <range>2.0</range> 
      <constant>1.0</constant>
      <linear>0.005</linear>
      <quadratic>0.001</quadratic>
    </attenuation>
    
    <cast_shadows>false</cast_shadows> 
  </light>
</gazebo>

<link name="check_chip_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.011 0.011 0.0001"/>
    </geometry>
  </visual>
  
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.011 0.011 0.0001"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="0.001"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia ixx="1e-8" iyy="1e-8" izz="1e-8" ixy="0" ixz="0" iyz="0"/>
  </inertial>
</link>

<joint name="world_to_check_chip" type="fixed">
  <parent link="world"/> 
  <child link="check_chip_link"/>
  <origin xyz="0.14 0 0.05005" rpy="0 0 0"/>
</joint>

<gazebo reference="check_chip_link">
  <visual>
    <material>
      <ambient>1 1 1 1</ambient>
      <diffuse>1 1 1 1</diffuse>
      <pbr>
        <metal>
         <albedo_map>model://robot_system_description/materials/textures/chip_pattern.jpg</albedo_map>
        </metal>
      </pbr>
    </material>
  </visual>
</gazebo>

<link name="red_check_chip_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.011 0.011 0.0001"/>
    </geometry>
    <material name="red_color">
      <color rgba="1.0 0.0 0.0 1.0"/>
    </material>
  </visual>
  
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.011 0.011 0.0001"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="0.001"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia ixx="1e-8" iyy="1e-8" izz="1e-8" ixy="0" ixz="0" iyz="0"/>
  </inertial>
</link>

<joint name="world_to_red_check_chip" type="fixed">
  <parent link="world"/> 
  <child link="red_check_chip_link"/>
  <origin xyz="0.14 0 0.153" rpy="0 0 0"/>
</joint>

<gazebo reference="red_check_chip_link">
  <material>Gazebo/Red</material>
</gazebo>

</robot>

