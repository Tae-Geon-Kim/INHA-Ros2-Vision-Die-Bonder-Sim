<?xml version="1.0" ?>
<robot name="robot_system" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find robot_system_description)/urdf/materials.xacro" />

<link name="world"/>
<joint name="fixed_to_world" type="fixed">
  <parent link="world"/>
  <child link="base_link"/>
</joint>

<link name="base_link">
  <inertial>
    <origin xyz="-0.036965141881106514 -9.562908641042548e-17 0.06102885117512971" rpy="0 0 0"/>
    <mass value="764.5040316870028"/>
    <inertia ixx="110.516115" iyy="99.10948" izz="203.495293" ixy="0.0" iyz="0.0" ixz="2.938225"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="black"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
  <collision name="base_work_surface_collision">
    <origin xyz="0 0 0.0495" rpy="0 0 0"/>
    <geometry>
      <box size="1.2 1.2 0.001"/>
    </geometry>
  </collision>
</link>

<link name="y_link_1">
  <inertial>
    <origin xyz="0.030000000000000013 0.0 0.0" rpy="0 0 0"/>
    <mass value="0.18"/>
    <inertia ixx="0.000991490446" iyy="0.000991490446" izz="0.000108" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.05 -0.0 -0.225" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/y_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.05 -0.0 -0.225" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/y_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="z_link_1">
  <inertial>
    <origin xyz="0.030000000000000013 -3.947459643111668e-18 0.0" rpy="0 0 0"/>
    <mass value="0.09"/>
    <inertia ixx="0.000029936306" iyy="0.000029936306" izz="0.000053980892" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.11 -0.0 -0.225" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/z_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.11 -0.0 -0.225" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/z_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="theta_link_1">
  <inertial>
    <origin xyz="0.0001732869481511634 -1.9700445167097035e-18 -0.0303093012095626" rpy="0 0 0"/>
    <mass value="0.05"/>
    <inertia ixx="0.000008476712" iyy="0.000007063927" izz="0.000004238356" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.14 0.0 -0.215" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/theta_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision name="picker_contact_collision">
    <origin xyz="0 0 -0.045" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.0035" length="0.010"/>
    </geometry>
  </collision>
</link>

<link name="x_link_1">
  <inertial>
    <origin xyz="8.91814442532711e-18 0.55 0.07933333333333334" rpy="0 0 0"/>
    <mass value="0.45"/>
    <inertia ixx="0.04749504459" iyy="0.000450802548" izz="0.04779425478" ixy="0.0" iyz="0.0" ixz="0.0"/>
  </inertial>
  <visual>
    <origin xyz="-0.0 0.55 -0.165" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/x_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="-0.0 0.55 -0.165" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://robot_system_description/meshes/x_link_1.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="joint_y" type="prismatic">
  <origin xyz="0.05 0.55 0.06" rpy="0 0 0"/>
  <parent link="x_link_1"/>
  <child link="y_link_1"/>
  <axis xyz="0.0 -1.0 0.0"/>
  <limit upper="0.4" lower="-0.4" effort="8" velocity="0.2"/>
  <dynamics damping="3.0" friction="0.0"/>
</joint>

<joint name="joint_z" type="prismatic">
  <origin xyz="0.06 0.0 0.0" rpy="0 0 0"/>
  <parent link="y_link_1"/>
  <child link="z_link_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit upper="0.115" lower="-0.115" effort="6" velocity="0.25"/>
  <dynamics damping="0.8" friction="0.0"/>
</joint>

<joint name="joint_theta" type="continuous">
  <origin xyz="0.03 -0.0 -0.01" rpy="0 0 0"/>
  <parent link="z_link_1"/>
  <child link="theta_link_1"/>
  <axis xyz="-0.0 0.0 -1.0"/>
  <limit effort="0.2" velocity="3.14"/>
  <dynamics damping="0.0002" friction="0.0"/>
</joint>

<joint name="joint_x" type="prismatic">
  <origin xyz="0.0 -0.55 0.165" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="x_link_1"/>
  <axis xyz="1.0 0.0 0.0"/>
  <limit upper="0.4" lower="-0.4" effort="12" velocity="0.2"/>
  <dynamics damping="6.0" friction="0.0"/>
</joint>

<gazebo reference="theta_link_1">
  <selfCollide>true</selfCollide>
  <kp>1000000.0</kp>
  <kd>100.0</kd>
  <maxVel>0.01</maxVel>
  <minDepth>0.0</minDepth>
  <sensor name="picker_contact_sensor" type="contact">
    <topic>/model/robot_system/picker/contact</topic>
    <contact>
      <collision>theta_link_1_fixed_joint_lump__picker_contact_collision_collision</collision>
    </contact>
    <always_on>1</always_on>
    <update_rate>100</update_rate>
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="macro_camera">
    <update_rate>5.0</update_rate>
    <topic>vision/macro_camera/image_raw</topic>
    <camera>
      <horizontal_fov>1.047</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.01</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose>0.0125 0 -0.038 0 1.5708 1.5708</pose> 
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="micro_camera_1">
    <update_rate>5.0</update_rate>
    <topic>vision/micro_camera_1/image_raw</topic>
    <camera>
      <horizontal_fov>0.11</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.005</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose> 0.006  0.006 -0.0435 0 1.5708 1.5708</pose> 
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="micro_camera_2">
    <update_rate>5.0</update_rate>
    <topic>vision/micro_camera_2/image_raw</topic>
    <camera>
      <horizontal_fov>0.11</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.005</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose> -0.006  0.006 -0.0435 0 1.5708 1.5708</pose>
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="micro_camera_3">
    <update_rate>5.0</update_rate>
    <topic>vision/micro_camera_3/image_raw</topic>
    <camera>
      <horizontal_fov>0.11</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.005</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose> -0.006  -0.006 -0.0435 0 1.5708 1.5708</pose> 
  </sensor>
</gazebo>

<gazebo reference="theta_link_1">
  <sensor type="camera" name="micro_camera_4">
    <update_rate>5.0</update_rate>
    <topic>vision/micro_camera_4/image_raw</topic>
    <camera>
      <horizontal_fov>0.11</horizontal_fov>
      <image>
        <width>1920</width>
        <height>1080</height>
      </image>
      <clip>
        <near>0.005</near>
        <far>100</far>
      </clip>
    </camera>
    <always_on>1</always_on>
    <visualize>false</visualize>
    <pose> 0.006  -0.006 -0.0435 0 1.5708 1.5708</pose> 
  </sensor>
</gazebo>

<gazebo>
  <plugin filename="libignition-gazebo-joint-state-publisher-system.so"
          name="ignition::gazebo::systems::JointStatePublisher">
    <topic>/model/robot_system/joint_state</topic>
    <joint_name>joint_x</joint_name>
    <joint_name>joint_y</joint_name>
    <joint_name>joint_z</joint_name>
    <joint_name>joint_theta</joint_name>
  </plugin>

  <plugin filename="libignition-gazebo-joint-position-controller-system.so"
          name="ignition::gazebo::systems::JointPositionController">
    <joint_name>joint_x</joint_name>
    <topic>/model/robot_system/joint/joint_x/cmd_pos</topic>
    <p_gain>220.0</p_gain>
    <i_gain>0.0</i_gain>
    <d_gain>20.0</d_gain>
    <cmd_max>12.0</cmd_max>
    <cmd_min>-12.0</cmd_min>
  </plugin>

  <plugin filename="libignition-gazebo-joint-position-controller-system.so"
          name="ignition::gazebo::systems::JointPositionController">
    <joint_name>joint_y</joint_name>
    <topic>/model/robot_system/joint/joint_y/cmd_pos</topic>
    <p_gain>140.0</p_gain>
    <i_gain>0.0</i_gain>
    <d_gain>10.5</d_gain>
    <cmd_max>8.0</cmd_max>
    <cmd_min>-8.0</cmd_min>
  </plugin>

  <plugin filename="libignition-gazebo-joint-position-controller-system.so"
          name="ignition::gazebo::systems::JointPositionController">
    <joint_name>joint_z</joint_name>
    <topic>/model/robot_system/joint/joint_z/cmd_pos</topic>
    <p_gain>2600.0</p_gain>
    <i_gain>1200.0</i_gain>
    <d_gain>40.0</d_gain>
    <i_max>3.0</i_max>
    <i_min>-3.0</i_min>
    <cmd_max>6.0</cmd_max>
    <cmd_min>-6.0</cmd_min>
  </plugin>

</gazebo>

<gazebo>
  <plugin filename="libignition-gazebo-joint-position-controller-system.so"
          name="ignition::gazebo::systems::JointPositionController">
    <joint_name>joint_theta</joint_name>
    <topic>/model/robot_system/joint/joint_theta/cmd_pos</topic>
    <p_gain>0.05</p_gain>
    <i_gain>0.0</i_gain>
    <d_gain>0.0008</d_gain>
    <cmd_max>0.2</cmd_max>
    <cmd_min>-0.2</cmd_min>
  </plugin>
</gazebo>

</robot>
